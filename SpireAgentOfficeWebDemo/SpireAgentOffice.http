@SpireAgentOffice_HostAddress = http://localhost:5184

### Health check
GET {{SpireAgentOffice_HostAddress}}/api/AIAgent/health
Accept: application/json

### ============================================
### Excel document processing (preset Sample.xlsx)
### ============================================

### Excel - Generate PDF
POST {{SpireAgentOffice_HostAddress}}/api/AIAgent/executeXls
Content-Type: application/json

{
    "instruction": "Convert sheet 1 to pdf",
    "saveFormat": "pdf"
}

### Excel - Generate XLSX
POST {{SpireAgentOffice_HostAddress}}/api/AIAgent/executeXls
Content-Type: application/json

{
    "instruction": "Generate corresponding charts in sheet1 based on current data",
    "saveFormat": "xlsx"
}

### Excel - Generate CSV
POST {{SpireAgentOffice_HostAddress}}/api/AIAgent/executeXls
Content-Type: application/json

{
    "instruction": "Export data from sheet1 to csv format",
    "saveFormat": "csv"
}

### Excel - Generate and return download URL
POST {{SpireAgentOffice_HostAddress}}/api/AIAgent/executeXls-and-return-url
Content-Type: application/json

{
    "instruction": "Convert sheet 1 to pdf",
    "saveFormat": "pdf"
}

